# Application
NODE_ENV=development
APP_NAME=DLORD_LIVE
APP_VERSION=1.0.0
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=dlord
DB_PASSWORD=dlord_secure_password
DB_NAME=dlord_live
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRATION=7d

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@dlordlive.com

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=dlord-live-videos
AWS_S3_URL=https://dlord-live-videos.s3.amazonaws.com

# Firebase
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email

# OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
APPLE_CLIENT_ID=your_apple_client_id
APPLE_CLIENT_SECRET=your_apple_client_secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Stripe
STRIPE_PUBLIC_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key

# Paystack
PAYSTACK_PUBLIC_KEY=pk_test_your_key
PAYSTACK_SECRET_KEY=sk_test_your_key

# Flutterwave
FLUTTERWAVE_PUBLIC_KEY=pk_test_your_key
FLUTTERWAVE_SECRET_KEY=sk_test_your_key

# Video Processing
FFMPEG_PATH=/usr/bin/ffmpeg
VIDEO_TEMP_DIR=/tmp/videos
MAX_VIDEO_SIZE=500000000
MAX_VIDEO_DURATION=600

# CDN
CDN_URL=https://cdn.dlordlive.com

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# API
API_URL=http://localhost:3000
GRAPHQL_URL=http://localhost:3000/graphql

# Frontend
FRONTEND_URL=http://localhost:3001

# WebSocket
WS_URL=ws://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
CORS_ORIGIN=http://localhost:3001,http://localhost:3000
CSRF_SECRET=your_csrf_secret
